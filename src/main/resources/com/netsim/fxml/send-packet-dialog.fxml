<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.netsim.presentation.controller.SendPacketDialogController"
      spacing="12" prefWidth="380"
      styleClass="dialog-root"
      stylesheets="@../css/dark-theme.css">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Enviar Pacote de Rede" styleClass="dialog-title"/>

    <Label text="Origem (IP):" styleClass="form-label"/>
    <ComboBox fx:id="cmbSource" maxWidth="Infinity" styleClass="form-input"/>

    <Label text="Destino (IP):" styleClass="form-label"/>
    <ComboBox fx:id="cmbDestination" maxWidth="Infinity" styleClass="form-input"/>

    <Label text="Payload (mensagem):" styleClass="form-label"/>
    <TextField fx:id="txtPayload" promptText="Hello, Network!" styleClass="form-input"/>

    <Label text="TTL (Time To Live):" styleClass="form-label"/>
    <Spinner fx:id="spnTtl" styleClass="form-input"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" text="Cancelar" styleClass="btn-secondary"/>
        <Button fx:id="btnSend"   text="Enviar Pacote" styleClass="btn-primary"/>
    </HBox>

</VBox>